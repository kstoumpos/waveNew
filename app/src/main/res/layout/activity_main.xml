<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000">

    <!-- Header / Logo -->
    <ImageView
        android:id="@+id/background_image"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/logomobile"
        android:background="@android:color/transparent"
        android:contentDescription="@null"
        android:layout_marginTop="50dp"
        android:layout_alignParentTop="true"
        android:layout_marginBottom="20dp" />

    <!-- Play / Stop Button — ανάμεσα στο logo και το κείμενο -->
    <FrameLayout
        android:id="@+id/playStopContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/background_image"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:elevation="8dp">

        <ImageButton
            android:id="@+id/playButton"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:padding="28dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_play"
            android:background="@drawable/bg_button_circle"
            android:contentDescription="@string/play" />

        <ImageButton
            android:id="@+id/stopButton"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:padding="28dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_stop"
            android:visibility="gone"
            android:background="@drawable/bg_button_circle"
            android:contentDescription="@string/stop" />

    </FrameLayout>

    <!-- Loading Status -->
    <TextView
        android:id="@+id/loadingStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/playStopContainer"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:text="@string/connecting"
        android:textColor="#FF9800"
        android:textStyle="bold"
        android:shadowColor="#000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="2"
        android:visibility="invisible" />

    <!-- Main Text — κάτω από το κουμπί -->
    <TextView
        android:id="@+id/mainText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        android:text="@string/main_text"
        android:textAlignment="center"
        android:textColor="#C2D2B9"
        android:textSize="48sp"
        android:layout_below="@+id/loadingStatus"
        android:visibility="visible" />

    <!-- Social Media Buttons — κάτω δεξιά -->
    <LinearLayout
        android:id="@+id/social_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="12dp"
        android:layout_marginEnd="5dp">

        <ImageButton
            android:id="@+id/instagram"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:contentDescription="@string/instagram"
            android:padding="6dp"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:src="@drawable/instagram" />

        <ImageButton
            android:id="@+id/facebook"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:contentDescription="@string/facebook"
            android:padding="6dp"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:src="@drawable/facebook" />

        <ImageButton
            android:id="@+id/spotify"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:contentDescription="@string/spotify"
            android:padding="6dp"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:src="@drawable/spotify"/>

        <ImageButton
            android:id="@+id/youtube"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:contentDescription="@string/youtube"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:background="@android:color/transparent"
            android:src="@drawable/youtube" />

        <ImageButton
            android:id="@+id/website"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:contentDescription="@string/website"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:background="@android:color/transparent"
            android:src="@drawable/website" />

    </LinearLayout>

</RelativeLayout>